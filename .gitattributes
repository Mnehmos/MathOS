# Shell entry points must remain executable as LF-delimited scripts on every checkout.
*.sh text eol=lf

# These vendored files are cryptographic inputs and must retain their upstream bytes.
schemas/mathcorpus/upstream-*/* -text
schemas/mcip/v1/upstream-*/* -text

# RL export embeds these schemas as deterministic member bytes on every platform.
schemas/release/rl-*.schema.json text eol=lf
