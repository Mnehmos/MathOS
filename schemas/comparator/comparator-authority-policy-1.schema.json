{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mnehmos.ai/mathos/schemas/comparator/authority-policy/1",
  "title": "MathOS Comparator Authority Policy v1",
  "type": "object",
  "additionalProperties": false,
